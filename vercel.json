{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "arom-studio.vercel.app"
        }
      ],
      "destination": "https://aromstudio.vercel.app/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/api/send-email", "destination": "/api/send-email.js" },
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
